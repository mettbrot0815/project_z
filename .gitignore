# =============================================================================
# Godot 4.6 Project .gitignore (Best Practices)
# =============================================================================

# =============================================================================
# Godot Generated Files (CRITICAL - Never commit these!)
# =============================================================================
.godot/
*.import
.import/
export_presets.cfg
user_data/
*.user

# =============================================================================
# IDE & Editor
# =============================================================================
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# =============================================================================
# Operating System Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable

# =============================================================================
# Temporary & Cache Files
# =============================================================================
*.tmp
*.tmp.*
*.temp
*.cache
*.log
*.nosync
*.bak
*.swp
*.swo
*~

# =============================================================================
# Build & Export
# =============================================================================
bin/
build/
obj/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.o
*.a
*.lib
*.class

# =============================================================================
# Local Configuration
# =============================================================================
.env
.env.local
*.env
secrets/
credentials/
keys/

# =============================================================================
# Other
# =============================================================================
# Test files
test_*.gd
test_*.tscn
verify_*.gd
verify_*.tscn
