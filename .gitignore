# =============================================================================
# Godot 4.6 Project .gitignore (Best Practices - Complete)
# =============================================================================

# =============================================================================
# Godot Generated Files (CRITICAL - Never commit these!)
# =============================================================================
.godot/
*.import
.import/
export_presets.cfg
user_data/
*.user

# =============================================================================
# UID Files (Import cache - regenerate on import)
# =============================================================================
*.uid

# =============================================================================
# IDE & Editor Files
# =============================================================================
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# =============================================================================
# Operating System Files
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Thumbs.db:encryptable

# =============================================================================
# Temporary & Cache Files
# =============================================================================
*.tmp
*.tmp.*
*.temp
*.cache
*.log
*.nosync
*.bak
*.swp
*.swo
*~
tmp/
temp/

# =============================================================================
# Build & Export Artifacts
# =============================================================================
bin/
build/
obj/
dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.o
*.a
*.lib
*.class
*.pck
.packed_scene/

# =============================================================================
# Compiled Python Cache
# =============================================================================
*.pyc
__pycache__/
.pytest_cache/
.coverage
htmlcov/

# =============================================================================
# Local Configuration & Secrets
# =============================================================================
.env
.env.local
*.env
secrets/
credentials/
keys/

# =============================================================================
# Test Files (unless explicitly named)
# =============================================================================
test_*.gd
test_*.tscn
verify_*.gd
verify_*.tscn

# =============================================================================
# Debug Files
# =============================================================================
debug/
debug_build/
*.debug
*.pdb

# =============================================================================
# Resource Files (optional - can be large)
# =============================================================================
# Uncomment if you want to exclude large asset imports
# *.tres
# *.uv
# *.ub