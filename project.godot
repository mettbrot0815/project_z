; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Z (1996) Recreation"
config/description="Faithful recreation of the 1996 Bitmap Brothers real-time strategy game"
config/version="0.1.0"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6")

[autoload]

TerritoryManager="*res://scripts/core/territory_manager.gd"
CombatManager="*res://scripts/core/combat_manager.gd"
GameState="*res://scripts/core/game_state.gd"
SelectionManager="*res://scripts/game/selection_manager.gd"
AIController="*res://scripts/game/ai_controller.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
GameManager="*res://scripts/game/game_manager.gd"

[debug]

settings/show_collision_shapes=false
settings/show_navigation=true

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/shrink=1

[dotnet]

project/assembly_name="Z (1996) Recreation"

