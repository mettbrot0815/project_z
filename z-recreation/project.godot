; Z (1996) Recreation - Godot 4.6 Project File

[application]

config/name="Z (1996) Recreation"
config/description="Faithful recreation of the 1996 Bitmap Brothers real-time strategy game"
run/main_scene="res://scenes/main.tscn"
config/icon="res://assets/sprites/icon.png"
config/version="0.1.0"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=true
window/vsync/vsync_mode=1
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/stretch/shrink=1

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/2d/use_texture_atlases=true
rendering/2d/snap_2d_vertices_to_pixel=true
anti_aliasing/quality/msaa_2d=0
environment/default_clear_color=Color(0.0, 0.0, 0.0, 1.0)

[physics]

2d/max_contacts_per_collision=8
common/max_physics_steps_per_frame=3
common/physics_ticks_per_second=60
threading/thread_model=2

